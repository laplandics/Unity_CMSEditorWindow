<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement name="ROOT" style="flex-grow: 1; flex-direction: row; justify-content: space-between; align-items: flex-start;">
        <ui:Label text="SystemName" name="SystemName" style="margin-left: 4px; padding-left: 0; padding-top: 0; margin-top: 0; margin-right: 4px; margin-bottom: 0; padding-right: 0; padding-bottom: 0; font-size: 12px; -unity-font-style: normal;"/>
        <ui:Button text="Delete" name="DeleteSystemButton" style="margin-top: 0; margin-right: 4px; margin-bottom: 0; margin-left: 4px; padding-top: 0; padding-right: 2px; padding-bottom: 0; padding-left: 2px; -unity-font-style: bold;"/>
    </ui:VisualElement>
</ui:UXML>
